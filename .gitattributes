# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare shell scripts as LF
*.sh text eol=lf

# Docker
Dockerfile text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.env text eol=lf

# Markdown
*.md text eol=lf

# Python
*.py text eol=lf
