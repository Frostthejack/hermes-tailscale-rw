# Environment Variables
# Copy to .env locally. In Railway, set these in Service → Variables.

# Required
OPENROUTER_API_KEY=sk-or-...
TS_AUTHKEY=tskey-auth-...

# Optional — Messaging (add when ready)
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
GH_TOKEN=

# Optional — SSH access (paste your public key)
SSH_PUBLIC_KEY=ssh-ed25519 AAAAC3...

# Optional — API server auth
API_SERVER_KEY=

# Optional — Model tuning
HERMES_MODEL=@preset/hermes
HERMES_PERSONALITY=kawaii
HINDSIGHT_BANK_ID=hermes-railway
