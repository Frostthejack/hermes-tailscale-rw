{
  "_comment": "SDXL workflow template using DualCLIPLoader (compatible with ComfyUI v0.22+). Replace UNETLoader model, CLIPTextEncode prompts, EmptyLatentImage dimensions, and KSampler params as needed.",
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "REPLACE_WITH_SDXL_UNET.safetensors",
      "weight_dtype": "default"
    }
  },
  "2": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "sdxl_vae.safetensors"
    }
  },
  "3": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "clip_g.safetensors",
      "type": "sdxl"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["3", 0],
      "text": "REPLACE_WITH_POSITIVE_PROMPT"
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["3", 0],
      "text": "REPLACE_WITH_NEGATIVE_PROMPT"
    }
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "latent_image": ["4", 0],
      "seed": -1,
      "steps": 30,
      "cfg": 7,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["2", 0]
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["8", 0],
      "filename_prefix": "sdxl_output"
    }
  }
}